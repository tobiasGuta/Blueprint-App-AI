# Copy this file to .env and fill in your API keys.
# Only ONE key is required — LiteLLM auto-detects which provider to use.

# ANTHROPIC_API_KEY=sk-ant-...       # Claude (Sonnet / Opus / Haiku)
# OPENAI_API_KEY=sk-...            # GPT-4o, GPT-4-turbo
GEMINI_API_KEY=AIza...           # Gemini 1.5 Flash / Pro
MOUSER_API_KEY=your_mouser_api_key_here   # Get free key at mouser.com/api
